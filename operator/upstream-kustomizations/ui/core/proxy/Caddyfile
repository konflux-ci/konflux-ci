{
	auto_https off
	admin off
	order inject_cached_vars before reverse_proxy
	file_watcher {
		cache kube_token /var/run/secrets/konflux-ci.dev/serviceaccount/token
		cache backend_token /var/run/secrets/konflux-ci.dev/backend/token
		watch /var/run/secrets/kubernetes.io/serviceaccount
		watch /mnt/trusted-ca
		watch /mnt/service-ca
		watch /mnt/serving-cert
	}
}

# TODO: protect metrics with kube-rbac-proxy sidecar (https://github.com/openshift/kube-rbac-proxy)
:2112 {
	metrics /metrics
}

:9443 {
	tls {
		get_certificate file {
			cert /mnt/serving-cert/tls.crt
			key /mnt/serving-cert/tls.key
		}
	}

	# Strip any client-supplied impersonation and proxy-auth headers to
	# prevent spoofing. This runs at the server level, before any
	# handle/route blocks.
	request_header -Impersonate-User
	request_header -Impersonate-Group
	request_header -Impersonate-Uid
	request_header -Impersonate-Extra-*
	request_header -X-User
	request_header -X-Group

	# Health endpoint for liveness/readiness probes
	handle /health {
		respond 200
	}

	# Segment bridge files
	handle /segment/* {
		root * /opt/app-root/src
		header Content-Type text/plain
		file_server
	}

	# OAuth2 proxy - browser-facing auth UI/callback
	handle /oauth2/* {
		reverse_proxy 127.0.0.1:6000
	}

	# Namespace lister (GET only on exact paths)
	# The namespace-lister performs in-memory RBAC authorization: it checks
	# RoleBindings for the user AND their groups to decide which namespaces
	# to return. Without group headers, a user only sees namespaces where
	# they are bound individually — group-based bindings are invisible.
	@nsListGet {
		method GET
		path /api/k8s/api/v1/namespaces /api/k8s/api/v1/namespaces/
	}
	handle @nsListGet {
		route {
			forward_auth 127.0.0.1:6000 {
				uri /oauth2/auth
				copy_headers X-Auth-Request-Email X-Auth-Request-Groups
			}
			impersonate {
				target_user X-User
				target_group X-Group
			}
			rewrite * /api/v1/namespaces
			reverse_proxy https://namespace-lister.namespace-lister.svc.cluster.local:8080 {
				header_down -X-Correlation-ID
				transport http {
					read_timeout 30m
					write_timeout 30m
					tls_trust_pool file /mnt/trusted-ca/ca-bundle.crt
				}
			}
		}
	}

	# Backend snippets (tekton-results, kubearchive, etc.) loaded from init-generated configs.
	# NOTE: Imported snippets MUST use paths more specific than /api/k8s/ to avoid
	# shadowing the Kube API catch-all handler below. Caddy evaluates handle blocks
	# by specificity (longest path match first), so e.g. /api/k8s/plugins/tekton-results/
	# is safe because it is more specific than /api/k8s/.
	import /mnt/caddy-snippets/*.caddy

	# WebSocket to Kube API
	handle_path /wss/k8s/* {
		route {
			forward_auth 127.0.0.1:6000 {
				uri /oauth2/auth
				copy_headers X-Auth-Request-Email X-Auth-Request-Groups
			}
			impersonate
			inject_cached_vars
			reverse_proxy https://kubernetes.default.svc {
				header_up Authorization "Bearer {http.vars.kube_token}"
				transport http {
					read_timeout 30m
					write_timeout 30m
					tls_trust_pool file /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
				}
			}
		}
	}

	# Kube API (catch-all for /api/k8s/)
	handle_path /api/k8s/* {
		route {
			forward_auth 127.0.0.1:6000 {
				uri /oauth2/auth
				copy_headers X-Auth-Request-Email X-Auth-Request-Groups
			}
			impersonate
			inject_cached_vars
			reverse_proxy https://kubernetes.default.svc {
				header_up Authorization "Bearer {http.vars.kube_token}"
				transport http {
					read_timeout 30m
					write_timeout 30m
					tls_trust_pool file /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
				}
			}
		}
	}

	# Dex Identity Provider
	handle /idp/* {
		reverse_proxy https://dex.konflux-ui.svc.cluster.local:9443 {
			header_up X-Forwarded-Port "9443"
			transport http {
				tls_trust_pool file /mnt/serving-cert/ca.crt
			}
		}
	}

	# Static SPA (catch-all, must be last)
	handle {
		root * /opt/app-root/src/static-content
		try_files {path} /index.html
		file_server
	}
}
